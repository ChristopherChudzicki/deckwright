# These values are auto-detected from `npx supabase status` at
# `npm run dev` boot via the supabase-local-env Vite plugin. Copying
# this to .env.local is optional and only needed if you want to point
# local dev at a non-default Supabase URL or key. Production builds
# MUST set these values explicitly via the host's env vars.

VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=<publishable-key-from-supabase-status>

# OAuth provider gates. Each provider's sign-in button is hidden
# unless its flag is "true". Set in the host's prod env vars; set
# in .env.local to test locally. Supabase must also be configured
# with the provider for sign-in to actually succeed.

# VITE_AUTH_GOOGLE_ENABLED=true
# VITE_AUTH_GITHUB_ENABLED=true
